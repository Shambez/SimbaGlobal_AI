{
  "expo": {
    "name": "SimbaGlobal AI",
    "slug": "simbaglobalai",
    "owner": "shambez",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "simbaglobalai",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/simba-global-ai-icon.png",
    "splash": {
      "image": "./assets/splash-simba-global-ai-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "extra": {
      "eas": {
        "projectId": "ba7d41e6-6081-4145-ad6e-86526cb1ff00"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ba7d41e6-6081-4145-ad6e-86526cb1ff00"
    },
    "ios": {
      "bundleIdentifier": "com.shambez.simbaglobalai",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs access to the camera for scanning and video.",
        "NSMicrophoneUsageDescription": "This app needs access to the microphone for voice features.",
        "NSLocationWhenInUseUsageDescription": "We use your location to personalize your experience.",
        "NSUserTrackingUsageDescription": "This identifier is used to deliver personalized ads.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.shambez.simbaglobalai",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE",
        "WAKE_LOCK",
        "INTERNET",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-simba-global-ai-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-camera",
      "expo-location",
      "expo-splash-screen",
      "expo-updates"
    ]
  }
}
